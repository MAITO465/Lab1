<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4F8"
    android:padding="20dp">

    <TextView
        android:id="@+id/tv_valeur_compteur"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="100dp"
        android:text="0"
        android:textColor="#2C3E50"
        android:textSize="60sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/btn_action_toast"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/tv_valeur_compteur"
        android:layout_marginTop="50dp"
        android:backgroundTint="#3498DB"
        android:text="Dire Bonjour"
        android:textColor="#FFFFFF" />

    <Button
        android:id="@+id/btn_action_plus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/btn_action_toast"
        android:layout_marginTop="15dp"
        android:backgroundTint="#2ECC71"
        android:text="Ajouter +1" />

</RelativeLayout>